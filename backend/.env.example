# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (CORS) — your Vercel frontend domain in production
FRONTEND_URL=http://localhost:5173

# Database (Supabase Postgres)
# For Vercel/serverless use the POOLED connection string (PgBouncer, port 6543)
# with ?pgbouncer=true for DATABASE_URL, and the DIRECT connection (port 5432)
# for DIRECT_URL (used by prisma migrate / db push).
# DATABASE_URL=postgresql://...:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://...:5432/postgres

# Supabase API Keys
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# JWT Secrets
# JWT_SECRET=
# JWT_EXPIRES_IN=1d

# Redis (OPTIONAL). Leave empty to disable caching and use in-memory rate
# limiting. On Vercel use Upstash and a rediss:// URL.
# REDIS_URL=

# Vercel Blob — durable image upload storage (set automatically when you
# create a Blob store in the Vercel dashboard; needed for image uploads on
# serverless since the filesystem is ephemeral).
# BLOB_READ_WRITE_TOKEN=

# Resend API Key (transactional email)
# RESEND_API_KEY=

# Termii API Key (SMS)
# TERMII_API_KEY=
# TERMII_SENDER_ID=CleanNaija
