# Frontend (Vite) environment variables.
# Copy to `.env` for local dev; set these in the Vercel project settings for prod.
# All client-exposed vars MUST be prefixed with VITE_.

# Base URL of the CleanNaija backend API (no trailing slash, no /api suffix).
# Local dev default if unset: http://localhost:5000
VITE_API_URL=http://localhost:5000

# Payment gateway PUBLIC keys (safe to expose; secret keys live on the backend).
VITE_PAYSTACK_PUBLIC_KEY=
VITE_FLUTTERWAVE_PUBLIC_KEY=

# Optional analytics / error tracking
VITE_SENTRY_DSN=
